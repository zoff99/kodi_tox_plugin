<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.koditox" name="KodiTox Video Engine" version="1.0.0" provider-name="Developer">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.qrcode" version="6.1.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <summary lang="en">Native media streaming engine via libkoditox.</summary>
        <description lang="en">Feeds video and PCM audio frames from Tox.</description>
        <assets>
            <icon>resources/icon.png</icon>
        </assets>
    </extension>
</addon>

